```gitignore
# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ==========================
# Virtual Environment
# ==========================
venv/
.venv/
env/

# ==========================
# Environment Variables
# ==========================
.env

# ==========================
# IDEs
# ==========================
.vscode/
.idea/

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Logs
# ==========================
*.log

# ==========================
# Testing
# ==========================
.pytest_cache/
.coverage
htmlcov/

# ==========================
# Generated PDFs
# ==========================
test_resume.pdf

# Ignore all generated resumes
generated_resumes/
output/
exports/

# ==========================
# Temporary Files
# ==========================
*.tmp
*.bak

# ==========================
# Build Artifacts
# ==========================
build/
dist/
*.egg-info/

# ==========================
# Jupyter
# ==========================
.ipynb_checkpoints/

# ==========================
# Streamlit (if used)
# ==========================
.streamlit/

# ==========================
# Cache
# ==========================
.cache/
```
